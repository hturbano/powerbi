{
    "name": "Modern Corporate",
    "author": "hturbano",
    "version": "1.0.0",
    "description": "A clean, professional theme suitable for executive dashboards and business-facing reports. Blue primary with semantic status colors.",
    "colors": {
        "primary": "#1A73E8",
        "primaryDark": "#1557B0",
        "primaryLight": "#E8F0FE",
        "secondary": "#5F6368",
        "secondaryDark": "#3C4043",
        "secondaryLight": "#F1F3F4",
        "accent": "#F9AB00",
        "success": "#34A853",
        "successDark": "#1E8E3E",
        "successLight": "#E6F4EA",
        "warning": "#FBBC04",
        "warningDark": "#F9AB00",
        "warningLight": "#FEF7E0",
        "danger": "#EA4335",
        "dangerDark": "#D93025",
        "dangerLight": "#FCE8E6",
        "neutral": "#9AA0A6",
        "neutralDark": "#5F6368",
        "neutralLight": "#F8F9FA",
        "background": "#FFFFFF",
        "surface": "#F8F9FA",
        "surfaceAlt": "#F1F3F4",
        "border": "#DADCE0",
        "text": "#202124",
        "textSecondary": "#5F6368",
        "textDisabled": "#9AA0A6"
    },
    "typography": {
        "fontFamily": "Segoe UI",
        "weights": {
            "light": 300,
            "regular": 400,
            "semibold": 600,
            "bold": 700
        },
        "sizes": {
            "title": 20,
            "subtitle": 14,
            "cardValue": 28,
            "cardLabel": 12,
            "axisLabel": 11,
            "legend": 11,
            "tooltip": 12,
            "button": 13
        }
    },
    "layout": {
        "pageWidth": 1280,
        "pageHeight": 720,
        "margin": 20,
        "gutter": 16,
        "cardPadding": 12,
        "borderRadius": 4,
        "shadow": "0 1px 3px rgba(0,0,0,0.12)"
    }
}
