{
    "name": "Dark Mode",
    "author": "hturbano",
    "version": "1.0.0",
    "description": "A dark theme optimized for operational dashboards and engineering reports. Reduced eye strain for always-on displays.",
    "colors": {
        "primary": "#8AB4F8",
        "primaryDark": "#669DF6",
        "primaryLight": "#1A73E8",
        "secondary": "#9AA0A6",
        "secondaryDark": "#5F6368",
        "secondaryLight": "#3C4043",
        "accent": "#FDD663",
        "success": "#81C995",
        "successDark": "#57BB8A",
        "successLight": "#1E3A2F",
        "warning": "#FDD663",
        "warningDark": "#F9AB00",
        "warningLight": "#3D3A1E",
        "danger": "#F28B82",
        "dangerDark": "#E57368",
        "dangerLight": "#3D1E1E",
        "neutral": "#9AA0A6",
        "neutralDark": "#5F6368",
        "neutralLight": "#2D2C2B",
        "background": "#1B1A19",
        "surface": "#2D2C2B",
        "surfaceAlt": "#3C3B3A",
        "border": "#3C4043",
        "text": "#E8EAED",
        "textSecondary": "#9AA0A6",
        "textDisabled": "#5F6368"
    },
    "typography": {
        "fontFamily": "Segoe UI",
        "weights": {
            "light": 300,
            "regular": 400,
            "semibold": 600,
            "bold": 700
        },
        "sizes": {
            "title": 20,
            "subtitle": 14,
            "cardValue": 28,
            "cardLabel": 12,
            "axisLabel": 11,
            "legend": 11,
            "tooltip": 12,
            "button": 13
        }
    },
    "layout": {
        "pageWidth": 1280,
        "pageHeight": 720,
        "margin": 20,
        "gutter": 16,
        "cardPadding": 12,
        "borderRadius": 4,
        "shadow": "0 1px 3px rgba(0,0,0,0.3)"
    }
}
